# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Sesión — firma HMAC de cookies httpOnly. Mínimo 32 chars. Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=cambiar-por-un-valor-largo-y-aleatorio
SESSION_TTL_HOURS=12

# Webhooks N8N (server-side)
WEBHOOK_LOGIN_URL=https://n8n.nexumai.online/webhook/d836faa4-c15a-40b2-9b6d-8912ce35f1db
WEBHOOK_EMAIL_URL=https://n8n.nexumai.online/webhook/632b1583-1c44-4504-9a09-d8f95fcdfa32
WEBHOOK_SAVE_URL=https://n8n.nexumai.online/webhook/944d3d14-b9e1-44e4-95be-e8ab62f05379

# Cookies — en prod con HTTPS: true. En local: false.
COOKIE_SECURE=false

# Modelo para roadmap (opcional)
# Default: claude-sonnet-4-6
# Alternativa: claude-opus-4-7 (más calidad, más caro y lento)
# ROADMAP_MODEL=claude-sonnet-4-6
# ROADMAP_MAX_TOKENS=20000

# CORS adicional (solo si el frontend corre en otro dominio distinto del API).
# Separado por coma. En Vercel misma-origin no hace falta.
# ALLOWED_ORIGINS=https://iniciacion.example.com
